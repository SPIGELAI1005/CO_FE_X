# Copy to .env and fill in values from your Supabase project dashboard.
# Never commit .env — the publishable (anon) key is safe for client bundles,
# but keeping secrets out of git is still required for service-role keys.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Server-only (SSR, webhooks, admin)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Match your dev server port (used for Stripe redirects when billing is enabled)
APP_URL=http://localhost:3000

# Stripe — optional; configure when partner billing is ready
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CAMPAIGN_BOOST=

# Keep false until Stripe keys above are set
VITE_FEATURE_STRIPE=false

# Playwright partner E2E (local + CI) — service role required to provision test user
E2E_PARTNER_EMAIL=e2e-partner@cofex.test
E2E_PARTNER_PASSWORD=CofexE2ePartner!2026
